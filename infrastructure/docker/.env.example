# PostgreSQL Configuration
POSTGRES_USER=agentic_user
POSTGRES_PASSWORD=agentic_password
POSTGRES_DB=agentic_orchestrator

# Redis Configuration
REDIS_PASSWORD=agentic_redis_password

# Kafka Configuration
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181

# Elasticsearch Configuration
ES_JAVA_OPTS=-Xms512m -Xmx512m

# Neo4j Configuration
NEO4J_AUTH=neo4j/agentic_neo4j_password

# Vault Configuration
VAULT_DEV_ROOT_TOKEN_ID=agentic-root-token

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=agentic_admin

# MinIO Configuration
MINIO_ROOT_USER=agentic_minio
MINIO_ROOT_PASSWORD=agentic_minio_password

# RabbitMQ Configuration
RABBITMQ_DEFAULT_USER=agentic_user
RABBITMQ_DEFAULT_PASS=agentic_password

# Environment
ENVIRONMENT=development
CLUSTER_NAME=agentic-orchestrator