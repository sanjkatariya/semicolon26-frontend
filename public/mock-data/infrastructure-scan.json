                "cwe": "CWE-732"
              },
              {
                "dependency": "namespace/payments",
                "issue_type": "Network Segmentation Gap",
                "severity": "HIGH",
                "current_version": "allow-all",
                "recommended_version": "default-deny",
                "explanation": "Missing network policies increase lateral movement risk.",
                "fix_strategy": "Apply default deny policies and explicit app-to-app allow rules."
              }
            ],
            "risk_score": 86,
            "priority_order": ["K8S-RBAC-001", "K8S-NET-002", "K8S-POD-003", "K8S-PSA-006"]
          }
        },
        {
          "agent": "infrastructure_report_agent",
          "step_name": "Report & Recommendations",
          "duration_seconds": 7,
          "output": {
            "validation": "passed",
            "recommendations_created": 6,
            "remediation_plan": "Tighten RBAC, add namespace network policies, disable privileged pods, pin images, and enforce Pod Security Admission.",
            "next_action": "Create policy remediation workflow"
          }
