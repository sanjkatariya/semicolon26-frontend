        },
        {
          "agent": "kubernetes_scanner_agent",
          "step_name": "Kubernetes Cluster Scan",
          "duration_seconds": 42,
          "output": {
            "scanner": "kubescape",
            "total_vulnerabilities": 6,
            "findings": [
              {
                "id": "K8S-RBAC-001",
                "title": "ClusterRole grants wildcard access",
                "severity": "critical",
                "cwe": "CWE-732",
                "package": "clusterrole/admin-automation",
                "repository_name": "prod-eks-us-east-1",
                "repository_url": "kubernetes://prod-eks-us-east-1",
                "affected_component": "rbac",
                "overview": "A ClusterRole grants wildcard verbs and resources.",
                "recommendation": "Replace wildcard permissions with least-privilege verbs and resource names."
              },
              {
                "id": "K8S-NET-002",
                "title": "Namespace has no default deny network policy",
                "severity": "high",
                "package": "namespace/payments",
                "repository_name": "prod-eks-us-east-1",
                "repository_url": "kubernetes://prod-eks-us-east-1",
                "affected_component": "network-policy",
                "overview": "Pods in payments can receive traffic from any namespace.",
                "recommendation": "Add default deny ingress and explicit allow rules."
              },
              {
                "id": "K8S-POD-003",
                "title": "Privileged container is running",
                "severity": "high",
                "cwe": "CWE-250",
                "package": "daemonset/log-forwarder",
                "repository_name": "prod-eks-us-east-1",
                "repository_url": "kubernetes://prod-eks-us-east-1",
                "affected_component": "pod-security",
                "overview": "The log-forwarder container runs with privileged mode enabled.",
                "recommendation": "Disable privileged mode and grant only the required Linux capabilities."
              },
              {
                "id": "K8S-IMG-004",
                "title": "Image tag uses latest",
                "severity": "medium",
                "package": "deployment/web",
                "repository_name": "prod-eks-us-east-1",
                "repository_url": "kubernetes://prod-eks-us-east-1",
                "affected_component": "image-policy",
                "overview": "A workload uses the mutable latest tag.",
                "recommendation": "Pin images by immutable tag or digest."
              },
              {
                "id": "K8S-SEC-005",
                "title": "Service account token automount is enabled",
                "severity": "medium",
                "package": "serviceaccount/default",
                "repository_name": "prod-eks-us-east-1",
                "repository_url": "kubernetes://prod-eks-us-east-1",
                "affected_component": "service-account",
                "overview": "Default service account tokens are mounted into pods that do not need Kubernetes API access.",
                "recommendation": "Set automountServiceAccountToken to false by default."
              },
              {
                "id": "K8S-PSA-006",
                "title": "Pod Security Admission is not enforced",
                "severity": "high",
                "package": "namespace/ingress-nginx",
                "repository_name": "prod-eks-us-east-1",
                "repository_url": "kubernetes://prod-eks-us-east-1",
                "affected_component": "pod-security",
                "overview": "The namespace does not enforce a restricted Pod Security Admission profile.",
                "recommendation": "Apply restricted Pod Security Admission labels or an equivalent policy engine."
              }
            ]
          }
        },
        {
          "agent": "kubernetes_analysis_agent",
          "step_name": "Cluster Risk Analysis",
          "duration_seconds": 11,
          "output": {
            "analysis": [
              {
                "dependency": "clusterrole/admin-automation",
                "issue_type": "RBAC Misconfiguration",
                "severity": "CRITICAL",
                "current_version": "wildcard",
                "recommended_version": "least-privilege",
