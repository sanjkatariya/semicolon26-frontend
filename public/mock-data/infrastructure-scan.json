      "agents": [
        {
          "agent": "cluster_access_agent",
          "step_name": "Cluster Access Check",
          "duration_seconds": 4,
          "output": {
            "target_type": "kubernetes_cluster",
            "cluster_name": "prod-eks-us-east-1",
            "kubeconfig_context": "prod-admin",
            "namespace": "all-namespaces",
            "api_server_reachable": true,
            "permissions": ["get pods", "list deployments", "list roles", "list networkpolicies"],
            "nodes": 8,
            "namespaces": 12,
            "workloads": 64
