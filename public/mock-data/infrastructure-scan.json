            "kubernetes_manifests": 18,
            "helm_charts": 2
          }
        },
        {
          "agent": "infrastructure_scanner_agent",
          "step_name": "IaC Security Scan",
          "duration_seconds": 31,
          "output": {
            "scanner": "checkov",
            "total_vulnerabilities": 4,
            "findings": [
              {
