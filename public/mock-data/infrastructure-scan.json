                "repository_name": "company/infrastructure",
                "repository_url": "https://github.com/company/infrastructure",
                "file_path": "k8s/overlays/prod/api-deployment.yaml",
                "overview": "allowPrivilegeEscalation is not set to false for the api container.",
                "recommendation": "Set securityContext.allowPrivilegeEscalation to false."
              },
              {
                "id": "CKV_K8S_21",
                "title": "Default namespace is used",
                "severity": "medium",
                "cwe": "CWE-668",
                "package": "kubernetes-namespace",
                "repository_name": "company/infrastructure",
                "repository_url": "https://github.com/company/infrastructure",
                "file_path": "k8s/base/service.yaml",
                "overview": "Workloads are deployed to the default namespace.",
                "recommendation": "Deploy workloads to an application-specific namespace."
              },
              {
                "id": "CKV_K8S_8",
                "title": "Liveness probe is missing",
                "severity": "high",
                "package": "kubernetes-deployment",
                "repository_name": "company/infrastructure",
                "repository_url": "https://github.com/company/infrastructure",
                "file_path": "k8s/base/worker-deployment.yaml",
                "overview": "The worker container does not define a liveness probe.",
                "recommendation": "Add an HTTP, TCP, or command liveness probe."
              },
              {
                "id": "CKV_K8S_35",
                "title": "Secret is mounted as environment variable",
                "severity": "critical",
                "cwe": "CWE-522",
                "package": "kubernetes-secret",
                "repository_name": "company/infrastructure",
                "repository_url": "https://github.com/company/infrastructure",
                "file_path": "k8s/base/api-deployment.yaml",
                "overview": "Database credentials are exposed through environment variables.",
                "recommendation": "Mount sensitive data from a secret volume or use an external secret provider."
              }
            ]
          }
        },
        {
          "agent": "infrastructure_analysis_agent",
          "step_name": "Risk Analysis",
          "duration_seconds": 9,
          "output": {
            "analysis": [
              {
                "dependency": "kubernetes-secret",
                "issue_type": "Infrastructure Misconfiguration",
                "severity": "CRITICAL",
                "current_version": "env-secret",
                "recommended_version": "secret-volume",
                "explanation": "Secret exposure has the highest blast radius because application pods can leak credentials through process inspection or debug dumps.",
                "fix_strategy": "Move credentials to a mounted secret volume or external secrets provider.",
                "cwe": "CWE-522"
              }
            ],
            "priority_order": ["CKV_K8S_35", "CKV_K8S_30", "CKV_K8S_8", "CKV_K8S_21"]
          }
        },
        {
          "agent": "infrastructure_report_agent",
          "step_name": "Report & Recommendations",
          "duration_seconds": 5,
          "output": {
            "validation": "passed",
            "recommendations_created": 4,
            "remediation_plan": "Open a PR that updates pod securityContext, namespace placement, health checks, and secret mounting.",
            "next_action": "Create remediation PR"
          }
        }
      ]
    },
    "kubernetes_cluster": {
      "target_label": "prod-eks-us-east-1/all-namespaces",
      "summary": {
        "total_vulnerabilities": 6,
        "critical": 1,
        "high": 3,
        "medium": 2,
        "validation": "passed",
        "workflow_type": "kubernetes_cluster_scan"
