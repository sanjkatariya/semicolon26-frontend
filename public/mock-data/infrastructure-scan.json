{
  "workflow": {
    "id": "infra-scan-workflow",
    "name": "Infrastructure Security Scan",
    "description": "Scan IaC repositories or live Kubernetes clusters with a compact 4-agent workflow",
    "agent_count": 4
  },
  "input_requirements": {
    "repo": [
      {
        "field": "repository_url",
        "label": "Repository URL",
        "required": true,
        "example": "https://github.com/company/infrastructure"
      },
      {
        "field": "branch",
        "label": "Branch",
        "required": true,
        "example": "main"
      },
      {
        "field": "manifest_path",
        "label": "Manifest or IaC Path",
        "required": false,
        "example": "k8s/overlays/prod"
      }
    ],
    "kubernetes_cluster": [
      {
        "field": "cluster_name",
        "label": "Cluster Name",
        "required": true,
        "example": "prod-eks-us-east-1"
      },
      {
        "field": "kubeconfig_context",
        "label": "Kubeconfig Context",
        "required": true,
        "example": "arn:aws:eks:us-east-1:123456789012:cluster/prod-eks"
      },
      {
        "field": "namespace",
        "label": "Namespace Scope",
        "required": false,
        "example": "default, payments, ingress-nginx"
      },
      {
        "field": "cloud_provider",
        "label": "Cloud Provider",
        "required": false,
        "example": "aws"
      },
      {
        "field": "compliance_profile",
        "label": "Compliance Profile",
        "required": false,
        "example": "cis-kubernetes"
      }
    ]
  },
  "sample_inputs": {
    "repo": {
      "repository_url": "https://github.com/company/infrastructure",
      "branch": "main",
      "manifest_path": "k8s/overlays/prod",
      "severity_levels": ["CRITICAL", "HIGH", "MEDIUM"],
      "compliance_profile": "cis-kubernetes"
    },
    "kubernetes_cluster": {
      "cluster_name": "prod-eks-us-east-1",
      "kubeconfig_context": "prod-admin",
      "namespace": "all-namespaces",
      "cloud_provider": "aws",
      "severity_levels": ["CRITICAL", "HIGH", "MEDIUM"],
      "compliance_profile": "cis-kubernetes",
      "include_rbac": true,
      "include_network_policies": true,
      "include_secrets": false,
      "timeout": 600
    }
  },
  "executions": {
    "repo": {
      "target_label": "company/infrastructure:k8s/overlays/prod",
      "summary": {
        "total_vulnerabilities": 4,
        "critical": 1,
        "high": 2,
        "medium": 1,
        "validation": "passed",
        "workflow_type": "infrastructure_repo_scan"
      },
      "agents": [
        {
          "agent": "infra_input_agent",
          "step_name": "Target Preparation",
          "duration_seconds": 6,
          "output": {
            "target_type": "repo",
            "repository_url": "https://github.com/company/infrastructure",
            "branch": "main",
            "manifest_path": "k8s/overlays/prod",
