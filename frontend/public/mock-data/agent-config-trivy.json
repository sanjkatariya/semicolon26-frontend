{
  "agent_id": "trivy-scanner-v1",
  "agent_name": "Trivy Container Scanner",
  "version": "1.0.0",
  "input_schema": {
    "type": "object",
    "properties": {
      "image_name": {
        "type": "string",
        "title": "Container Image",
        "description": "Docker image to scan (format: repository:tag)",
        "validation": {
          "required": true,
          "pattern": "^[a-zA-Z0-9._/-]+:[a-zA-Z0-9._-]+$"
        },
        "ui": {
          "widget": "input",
          "placeholder": "nginx:latest",
          "help_text": "Example: nginx:latest, ubuntu:22.04",
          "icon": "🐳"
        }
      },
      "severity_levels": {
        "type": "multiselect",
        "title": "Severity Levels",
        "description": "Select which severity levels to scan for",
        "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "UNKNOWN"],
        "default": ["CRITICAL", "HIGH"],
        "validation": {
          "required": true
        },
        "ui": {
          "widget": "multiselect",
          "help_text": "Select one or more severity levels to include in scan",
          "icon": "⚠️"
        }
      },
      "scan_type": {
        "type": "select",
        "title": "Scan Type",
        "description": "Type of vulnerabilities to scan",
        "enum": ["os", "library", "all"],
        "default": "all",
        "ui": {
          "widget": "select",
          "help_text": "OS: Operating system packages, Library: Application dependencies, All: Both",
          "icon": "🔍"
        }
      },
      "ignore_unfixed": {
        "type": "boolean",
        "title": "Ignore Unfixed Vulnerabilities",
        "description": "Skip vulnerabilities that don't have fixes available",
        "default": false,
        "ui": {
          "widget": "checkbox",
          "help_text": "Enable to skip vulnerabilities without available fixes"
        }
      },
      "timeout": {
        "type": "number",
        "title": "Scan Timeout",
        "description": "Maximum time for scan in seconds",
        "default": 300,
        "validation": {
          "min": 30,
          "max": 3600
        },
        "ui": {
          "widget": "number",
          "placeholder": "300",
          "help_text": "Timeout in seconds (30-3600)",
          "icon": "⏱️"
        }
      }
    },
    "required": ["image_name", "severity_levels"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "scan_id": {
        "type": "string",
        "title": "Scan ID"
      },
      "image": {
        "type": "string",
        "title": "Scanned Image"
      },
      "scan_time": {
        "type": "string",
        "format": "datetime",
        "title": "Scan Timestamp"
      },
      "status": {
        "type": "string",
        "title": "Scan Status",
        "enum": ["success", "failed", "partial"],
        "ui": {
          "widget": "badge",
          "colors": {
            "success": "green",
            "failed": "red",
            "partial": "yellow"
          }
        }
      },
      "scan_duration": {
        "type": "number",
        "title": "Scan Duration",
        "ui": {
          "widget": "metric",
          "icon": "⏱️",
          "color": "#3b82f6"
        }
      },
      "total_vulnerabilities": {
        "type": "number",
        "title": "Total Vulnerabilities",
        "ui": {
          "widget": "metric",
          "icon": "🐛",
          "color": "#ef4444"
        }
      },
      "vulnerabilities_by_severity": {
        "type": "object",
        "title": "Vulnerabilities by Severity",
        "properties": {
          "CRITICAL": { "type": "number" },
          "HIGH": { "type": "number" },
          "MEDIUM": { "type": "number" },
          "LOW": { "type": "number" }
        },
        "ui": {
          "widget": "bar-chart",
          "colors": {
            "CRITICAL": "#ef4444",
            "HIGH": "#f97316",
            "MEDIUM": "#eab308",
            "LOW": "#3b82f6"
          }
        }
      },
      "vulnerabilities": {
        "type": "array",
        "title": "Vulnerability Details",
        "items": {
          "type": "object",
          "properties": {
            "cve_id": { "type": "string", "title": "CVE ID" },
            "severity": { "type": "string", "title": "Severity" },
            "package": { "type": "string", "title": "Package" },
            "installed_version": { "type": "string", "title": "Installed" },
            "fixed_version": { "type": "string", "title": "Fixed In" },
            "description": { "type": "string", "title": "Description" }
          }
        },
        "ui": {
          "widget": "data-table",
          "columns": ["cve_id", "severity", "package", "installed_version", "fixed_version"],
          "sortable": true,
          "filterable": true
        }
      }
    }
  },
  "ui_config": {
    "input_layout": {
      "sections": [
        {
          "title": "Target Configuration",
          "fields": ["image_name", "scan_type"],
          "columns": 2
        },
        {
          "title": "Scan Options",
          "fields": ["severity_levels", "ignore_unfixed", "timeout"],
          "columns": 1
        }
      ]
    },
    "output_layout": {
      "sections": [
        {
          "title": "Scan Summary",
          "fields": ["scan_id", "image", "scan_time", "status", "scan_duration"],
          "columns": 3
        },
        {
          "title": "Vulnerability Overview",
          "fields": ["total_vulnerabilities", "vulnerabilities_by_severity"],
          "columns": 2
        },
        {
          "title": "Detailed Results",
          "fields": ["vulnerabilities"],
          "columns": 1
        }
      ]
    }
  }
}